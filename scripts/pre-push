#!/usr/bin/env bash
set -e

echo "=== Pre-push checks ==="

echo "[1/4] ruff check..."
uv run ruff check opencontext/ tests/

echo "[2/4] ruff format..."
uv run ruff format --check opencontext/ tests/

echo "[3/4] mypy..."
uv run mypy opencontext/

echo "[4/4] pytest..."
uv run pytest -m unit -v --tb=short

echo "=== All checks passed ==="
